{
	"name": "@btakita/herbaliciousbliss-site",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"build": "bun build.ts",
		"clear": "rm -rf ./dist",
		"dev": "bun run dev:sourcemap__resolve__bun",
		"dev:raw": "bun index.ts",
		"dev:sourcemap__resolve__bun": "bin/sourcemap__resolve__bun.ts -f index.ts",
		"db:drop": "drizzle-kit drop",
		"db:generate": "drizzle-kit generate:sqlite",
		"db:migrate": "bun ./db/migrate.ts",
		"db:push": "drizzle-config push:sqlite",
		"start": "bin/sourcemap__resolve__bun.ts -f start.ts",
		"clean": "rm -rf ./dist"
	},
	"dependencies": {
		"@ctx-core/preprocess": "^0.1.3",
		"@ctx-core/source-map": "^0.2.110",
		"@btakita/domain--server--herbaliciousbliss": "workspace:*",
		"@btakita/ui--any--herbaliciousbliss": "workspace:*",
		"@btakita/ui--server--herbaliciousbliss": "workspace:*",
		"@rappstack/domain--any--blog": "^0.1.0",
		"@rappstack/domain--server": "^0.1.0",
		"@rappstack/domain--server--auth": "^0.1.0",
		"@rappstack/domain--server--blog": "^0.1.0",
		"@rappstack/ui--any": "^0.1.0",
		"@rappstack/ui--any--blog": "^0.1.0",
		"@rappstack/ui--browser--blog": "^0.1.0",
		"@rappstack/ui--server": "^0.1.0",
		"@rappstack/ui--server--blog": "^0.1.0",
		"@rebuildjs/tailwindcss": "^0.10.49",
		"@tailwindcss/forms": "^0.5.7",
		"@tailwindcss/typography": "^0.5.13",
		"arctic": "^1.9.1",
		"cssnano": "^7.0.4",
		"ctx-core": "^7.2.27",
		"drizzle-kit": "^0.23.0",
		"drizzle-orm": "^0.32.0",
		"hono": "^4.0.0",
		"esbuild": "^0.23.0",
		"esmcss": "^0.2.12",
		"marked": "^13.0.2",
		"nodemailer": "^6.9.14",
		"oslo": "^1.2.1",
		"picocolors": "^1.0.1",
		"rebuildjs": "^0.70.37",
		"relementjs": "^0.80.26",
		"rhonojs": "*",
		"tailwindcss": "^3.4.4"
	},
	"devDependencies": {
		"bun-types": "latest"
	}
}